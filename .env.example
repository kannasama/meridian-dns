# Meridian DNS — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# See docs/CONFIGURATION.md for the complete reference.

# ── Required secrets (generate with: openssl rand -hex 32) ───────────────────
DNS_MASTER_KEY=
DNS_JWT_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
DNS_DB_PASSWORD=dns_dev_password
# DNS_DB_URL=postgresql://dns:password@db:5432/meridian_dns  # set automatically in Docker Compose
# DNS_DB_POOL_SIZE=10

# ── HTTP server ──────────────────────────────────────────────────────────────
# DNS_HTTP_PORT=8080
# DNS_HTTP_THREADS=4
# DNS_LOG_LEVEL=info

# ── Web UI ───────────────────────────────────────────────────────────────────
# DNS_UI_DIR=/opt/meridian-dns/ui

# ── Session & security ───────────────────────────────────────────────────────
# DNS_SESSION_ABSOLUTE_TTL_SECONDS=86400
# DNS_JWT_TTL_SECONDS=28800

# ── OIDC/SAML (required for federated auth) ─────────────────────────────────
# DNS_BASE_URL=https://dns.example.com

# ── Audit ────────────────────────────────────────────────────────────────────
# DNS_AUDIT_RETENTION_DAYS=365
# DNS_AUDIT_STDOUT=false
# DNS_AUDIT_DB_URL=  # Separate audit DB URL (optional, for least-privilege purge)

# ── Deployment & sync ────────────────────────────────────────────────────────
# DNS_DEPLOYMENT_RETENTION_COUNT=10
# DNS_SYNC_CHECK_INTERVAL=3600

# ── GitOps ───────────────────────────────────────────────────────────────────
# DNS_GITOPS_BASE_PATH=/var/meridian-dns/repos
# DNS_BACKUP_GIT_REPO_ID=0
# DNS_BACKUP_AUTO_INTERVAL_SECONDS=0
